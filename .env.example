# Chave da API Gemini — use APENAS no servidor (não vai para o bundle do Vite).
# Copie para .env ou .env.local na raiz (não commite; .env.local tem prioridade).
GEMINI_API_KEY=""

# Modelo opcional (padrão: gemini-2.0-flash)
# GEMINI_MODEL="gemini-2.0-flash"

# Porta da API Express (desenvolvimento: Vite faz proxy de /api → esta porta)
# PORT=3001

# Se rodar só o Vite (`npm run dev:web`), aponte o browser direto para a API (CORS liberado em dev no servidor):
# VITE_API_ORIGIN=http://localhost:3001

# Produção: `npm run build` e depois `npm start` — o servidor Express serve dist/ e /api.
# Em PaaS (ex.: Cloud Run), defina GEMINI_API_KEY e normalmente PORT é injetado automaticamente.

# --- Vercel (dashboard: Project → Settings → Environment Variables) ---
# GEMINI_API_KEY   obrigatório para o assistente IA
# GEMINI_MODEL     opcional
# Não use VITE_API_ORIGIN no mesmo projeto: o front chama /api na mesma origem.

# URL pública do app (opcional, integrações legadas)
# APP_URL="https://seu-dominio.com"
