{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "framework": "vite",
  "rewrites": [
    {
      "source": "/((?!api/).*)",
      "destination": "/index.html"
    }
  ],
  "functions": {
    "api/ai/suggest-config.ts": {
      "maxDuration": 60,
      "includeFiles": "api/ai/**"
    },
    "api/**/*.ts": {
      "maxDuration": 60
    }
  }
}
